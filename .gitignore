# Claude Code state. gradient generates into these paths itself: `apply` writes
# slash commands to commands/, `autopilot` installs its Stop hook into
# settings.json. Both are per-developer artifacts, not shared project config —
# committing the hook would run `gradient respond` on contributors' machines.
.claude/worktrees/
.claude/settings.json
.claude/settings.local.json
.claude/commands/

# The marketing site lives in a separate private repo (gradient-web).
# Guard against it being re-added to this public repo.
webapp/

# Claude Code transcript exports use a timestamped slug filename. Keep raw
# sessions local: they can contain account details and unrelated conversation.
/20??-??-??-??????-*.txt
